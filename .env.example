# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=huskypark
POSTGRES_PASSWORD=changeme
POSTGRES_DB=huskypark_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
MONGO_DB=huskypark_mongo

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth (JWT) ────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── OpenAI (AI Recommendation) ────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Weather API ───────────────────────────────────────────────
OPENWEATHER_API_KEY=...
OPENWEATHER_LAT=45.5598
OPENWEATHER_LON=-94.1512

# ── Azure (production only) ───────────────────────────────────
# Set these in GitHub → Settings → Secrets and variables → Actions
AZURE_CREDENTIALS={"clientId":"...","clientSecret":"...","subscriptionId":"...","tenantId":"..."}
AZURE_STATIC_WEB_APPS_API_TOKEN=...
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
